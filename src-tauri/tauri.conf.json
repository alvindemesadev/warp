{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warp",
  "version": "1.0.0",
  "identifier": "com.alvin.warp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Warp",
        "width": 480,
        "height": 660,
        "minWidth": 440,
        "minHeight": 560,
        "maxWidth": 700,
        "maxHeight": 900,
        "center": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
