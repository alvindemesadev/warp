{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warp",
  "version": "1.0.0",
  "identifier": "com.alvin.warp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Warp",
        "width": 560,
        "height": 820,
        "minWidth": 480,
        "minHeight": 600,
        "maxWidth": 800,
        "maxHeight": 1100,
        "center": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Alvin",
    "copyright": "© 2026 Alvin. MIT Licensed.",
    "category": "Utility",
    "shortDescription": "High-speed file transfer for Windows",
    "longDescription": "Warp wraps Windows robocopy in a clean interface with real-time progress, live transfer speed, and per-transfer summaries.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
